# SMTP credentials (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rgmc.apps@gmail.com
SMTP_PASSWORD=your_16char_app_password_here
SENDER_EMAIL=rgmc.apps@gmail.com

# Developer email — problem reports are sent here
DEVELOPER_EMAIL=it.arellanoerwin@gmail.com

# Approver email — access requests are forwarded here for approval/rejection
APPROVER_EMAIL=it.arellanoerwin@gmail.com

# Supabase — access control database
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://eesrzpgmsrbhjeenfojq.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Base URL of this deployed app — used to build approve/reject links in emails.
# Example: https://your-service-935246372408.run.app
# Leave blank to auto-detect from the incoming request (may not work behind proxies).
GATEWAY_BASE_URL=

# Server port (Cloud Run injects this automatically — do not set on Cloud Run)
PORT=8080
